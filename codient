DEFAULT_IGNORE_PATTERNS = [
    "node_modules", "vendor", ".venv", "venv", "env", "__pycache__",
    "site-packages", ".pip", "bower_components", "jspm_packages",
    "dist", "build", "out", ".next", ".nuxt", ".output", "target", "bin", "obj",
    ".git", ".svn", ".hg", ".idea", ".vscode",
    ".DS_Store", "Thumbs.db",
    "coverage", ".cache", ".pytest_cache", ".mypy_cache", "htmlcoverage",
]

DEFAULT_IGNORE_EXTENSIONS = [
    ".log", ".tmp", ".temp", ".suo", ".user",
    "package-lock.json", "yarn.lock", "composer.lock", "Pipfile.lock", "poetry.lock",
]


def load_ignore_patterns(current_dir):
    patterns = set(DEFAULT_IGNORE_PATTERNS)
    ext_patterns = set(DEFAULT_IGNORE_EXTENSIONS)

    for ignore_file in [".gitignore", ".codientignore"]:
        ignore_path = os.path.join(current_dir, ignore_file)
        if os.path.isfile(ignore_path):
            try:
                content = read_file(ignore_path)
                for line in content.splitlines():
                    line = line.strip()
                    if not line or line.startswith("#"):
                        continue
                    clean = line.rstrip("/")
                    if clean.startswith("*."):
                        ext_patterns.add(clean[1:])
                    else:
                        patterns.add(clean)
            except Exception:
                pass

    return patterns, ext_patterns


def build_tree(current_dir, max_depth=3):
    """Build a directory tree string, respecting ignore patterns."""
    ignore_dirs, ignore_exts = load_ignore_patterns(current_dir)
    lines = [f"{os.path.basename(current_dir)}/"]

    def _walk(path, prefix, depth):
        if depth > max_depth:
            return
        try:
            entries = sorted(os.listdir(path))
        except PermissionError:
            return

        filtered = []
        for entry in entries:
            full = os.path.join(path, entry)
            if entry in ignore_dirs:
                continue
            if os.path.isfile(full):
                _, ext = os.path.splitext(entry)
                if ext in ignore_exts or entry in ignore_exts:
                    continue
            filtered.append(entry)

        for i, entry in enumerate(filtered):
            is_last = i == len(filtered) - 1
            connector = "└── " if is_last else "├── "
            full = os.path.join(path, entry)
            if os.path.isdir(full):
                lines.append(f"{prefix}{connector}{entry}/")
                extension = "    " if is_last else "│   "
                _walk(full, prefix + extension, depth + 1)
            else:
                lines.append(f"{prefix}{connector}{entry}")

    _walk(current_dir, "", 1)
    return "\n".join(lines)


def ensure_dir(path):
    os.makedirs(path, exist_ok=True)


def read_file(path):
    with open(path, 'r', encoding='utf-8') as f:
        return f.read()


def write_file(path, content):
    with open(path, 'w', encoding='utf-8') as f:
        f.write(content)


def show_history(backup_dir, file_name):
    base_name = os.path.splitext(file_name)[0]
    ext = os.path.splitext(file_name)[1]
    pattern = os.path.join(backup_dir, f"{base_name}_*{ext}")
    backups = glob.glob(pattern)

    if not backups:
        print(f"\n❌ No backup versions found for '{file_name}'")
        return

    backup_list = []
    for backup in backups:
        timestamp_str = backup.replace(backup_dir, "").replace(base_name, "").replace(ext, "").replace("_", "").replace("/", "")
        if timestamp_str.isdigit() and len(timestamp_str) == 14:
            try:
                dt = datetime.strptime(timestamp_str, "%Y%m%d%H%M%S")
                backup_list.append((dt, timestamp_str, backup))
            except:
                continue

    backup_list.sort(reverse=True)

    print(f"\n📋 Backup history for '{file_name}':")
    print("=" * 70)
    for idx, (dt, ts, path) in enumerate(backup_list, 1):
        print(f"{idx}. Time: {dt.strftime('%Y-%m-%d %H:%M:%S')} (timestamp: {ts})")
        print(f"   Path: {path}")
    print("=" * 70)


def rollback_file(backup_dir, file_name, timestamp=None):
    current_dir = os.getcwd()
    target_file_path = os.path.join(current_dir, file_name)

    if not os.path.exists(target_file_path):
        print(f"❌ File '{file_name}' does not exist in current directory")
        return False

    base_name = os.path.splitext(file_name)[0]
    ext = os.path.splitext(file_name)[1]

    if timestamp:
        backup_path = os.path.join(backup_dir, f"{base_name}_{timestamp}{ext}")
        if os.path.exists(backup_path):
            current_backup = os.path.join(backup_dir, f"{base_name}_{time.strftime('%Y%m%d%H%M%S')}{ext}")
            current_content = read_file(target_file_path)
            write_file(current_backup, current_content)
            print(f"🗂 Backup of current version: {current_backup}")

            backup_content = read_file(backup_path)
            write_file(target_file_path, backup_content)
            print(f"✅ File '{file_name}' rolled back to version {timestamp}")
            return True
        else:
            print(f"❌ Version with timestamp '{timestamp}' not found for '{file_name}'")
            return False
    else:
        pattern = os.path.join(backup_dir, f"{base_name}_*{ext}")
        backups = glob.glob(pattern)

        if not backups:
            print(f"❌ No backup versions found for '{file_name}'")
            return False

        latest_backup = max(backups, key=os.path.getmtime)

        ts = latest_backup.replace(backup_dir, "").replace(base_name, "").replace(ext, "").replace("_", "").replace("/", "")

        current_backup = os.path.join(backup_dir, f"{base_name}_{time.strftime('%Y%m%d%H%M%S')}{ext}")
        current_content = read_file(target_file_path)
        write_file(current_backup, current_content)
        print(f"🗂 Backup of current version: {current_backup}")

        backup_content = read_file(latest_backup)
        write_file(target_file_path, backup_content)
        print(f"✅ File '{file_name}' rolled back to latest version (timestamp: {ts})")
        return True


def generate_diff_html(diffs, output_path):
    html_content = """
    <html>
    <head>
        <meta charset="UTF-8">
        <title>Codient Diff Report</title>
        <style>
            body { font-family: monospace; background: #111; color: #eee; }
            .file { margin-bottom: 40px; }
            .filename { font-size: 18px; margin: 10px 0; }

            .line {
                display: inline-block;
                white-space: pre;
                padding-left: 6px;
                margin: 0;
            }

            .added {
                background: #144212;
                color: #9cff9c;
            }

            .removed {
                background: #4a1212;
                color: #ff9c9c;
            }

            .same {
                color: #ccc;
            }

            .added::before {
                content: "+ ";
                color: #6fff6f;
                user-select: none;
            }

            .removed::before {
                content: "- ";
                color: #ff6f6f;
                user-select: none;
            }

            .same::before {
                content: "  ";
                user-select: none;
            }

            pre {
                padding: 10px;
                overflow-x: auto;
            }
        </style>
    </head>
    <body>
    <h1>Codient Diff Report</h1>
    """

    for file_name, diff_lines, action in diffs:
        action_label = "🆕 NEW FILE" if action == "create" else "✏️ EDITED"
        html_content += f"<div class='file'><div class='filename'>{action_label} &mdash; {file_name}</div><pre>"

        for line in diff_lines:
            if line.startswith('+++') or line.startswith('---'):
                continue

            clean_line = line[1:] if line.startswith(('+', '-')) else line

            if line.startswith('+'):
                html_content += f"<span class='line added'>{clean_line}</span>\n"
            elif line.startswith('-'):
                html_content += f"<span class='line removed'>{clean_line}</span>\n"
            else:
                html_content += f"<span class='line same'>{clean_line}</span>\n"

        html_content += "</pre></div>"

    html_content += "</body></html>"

    write_file(output_path, html_content)

