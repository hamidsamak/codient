def parse_args():
    overwrite = False
    context_files = []
    context_mode = False
    debug = False
    history_mode = False
    rollback_mode = False
    rollback_timestamp = None
    target_file = None
    browser_only_mode = False
    proxy = None
    model = "deepseek"

    if "--proxy" in sys.argv:
        proxy_index = sys.argv.index("--proxy")
        if proxy_index + 1 < len(sys.argv):
            proxy = sys.argv[proxy_index + 1]
        else:
            print("❌ Error: Please specify proxy after --proxy")
            sys.exit(1)

        sys.argv.remove("--proxy")
        sys.argv.remove(proxy)

    if "--model" in sys.argv:
        model_index = sys.argv.index("--model")
        if model_index + 1 < len(sys.argv):
            model = sys.argv[model_index + 1].lower()
            if model not in ("claude", "chatgpt", "deepseek"):
                print("❌ Error: Invalid model. Choices are: claude, chatgpt")
                sys.exit(1)
        else:
            print("❌ Error: Please specify model after --model")
            sys.exit(1)

        sys.argv.remove("--model")
        sys.argv.remove(sys.argv[sys.argv.index(model)])

    if "--browser" in sys.argv:
        browser_only_mode = True
        return None, None, None, None, None, history_mode, rollback_mode, target_file, None, browser_only_mode, proxy, model

    if "--history" in sys.argv:
        history_mode = True
        history_index = sys.argv.index("--history")
        if history_index + 1 < len(sys.argv) and not sys.argv[history_index + 1].startswith("--"):
            target_file = sys.argv[history_index + 1]
        else:
            print("❌ Error: Please specify filename after --history")
            sys.exit(1)
        return None, None, None, None, None, history_mode, rollback_mode, target_file, None, browser_only_mode, proxy, model

    if "--rollback" in sys.argv:
        rollback_mode = True
        rollback_index = sys.argv.index("--rollback")
        if rollback_index + 1 < len(sys.argv) and not sys.argv[rollback_index + 1].startswith("--"):
            target_file = sys.argv[rollback_index + 1]
        else:
            print("❌ Error: Please specify filename after --rollback")
            sys.exit(1)

        if "--timestamp" in sys.argv:
            ts_index = sys.argv.index("--timestamp")
            if ts_index + 1 < len(sys.argv):
                rollback_timestamp = sys.argv[ts_index + 1]

        return None, None, None, None, None, history_mode, rollback_mode, target_file, rollback_timestamp, browser_only_mode, proxy, model

    if "--overwrite" in sys.argv:
        overwrite = True
        sys.argv.remove("--overwrite")

    if "--debug" in sys.argv:
        debug = True
        sys.argv.remove("--debug")

    if len(sys.argv) < 2:
        print_usage()
        sys.exit(1)

    question = sys.argv[1]
    raw_args = sys.argv[2:]

    cleaned_args = []
    i = 0

    while i < len(raw_args):
        if raw_args[i] == "--context":
            context_mode = True
            i += 1
            continue

        if raw_args[i] == "--":
            context_mode = False
            i += 1
            continue

        if context_mode:
            context_files.append(raw_args[i])
        else:
            cleaned_args.append(raw_args[i])

        i += 1

    return question, cleaned_args, context_files, overwrite, debug, history_mode, rollback_mode, target_file, rollback_timestamp, browser_only_mode, proxy, model


def collect_files(file_list, current_dir):
    valid_files = []

    for file_path in file_list:
        if not os.path.isabs(file_path):
            file_path = os.path.join(current_dir, file_path)

        file_name = os.path.basename(file_path)

        if os.path.isfile(file_path):
            valid_files.append((file_name, file_path))
            print(f"✅ File found: {file_name}")
        else:
            print(f"⚠️ File does not exist: {file_path}")

    if not valid_files and file_list:
        print("⚠️ None of the specified files were found.")

    return valid_files


def build_prompt(question, context_files, valid_files, current_dir):
    full_question = f"""{question}

Rules:
1. Return ONLY a single fenced XML code block (```xml ... ```), no explanation or commentary.
2. Wrap each file like: <file name="..." path="..." action="edit|create">code here</file>
   - Use action="edit" for existing files that are being modified.
   - Use action="create" for brand new files that do not exist yet.
   - For path, use only the filename (e.g. app.py) or a relative path (e.g. utils/helpers.py). Do NOT use absolute paths.
3. Do NOT include readonly files in the output under any circumstances.
Current working directory: {current_dir}
"""

    for file_name in context_files:
        file_path = os.path.join(current_dir, file_name)
        if os.path.isfile(file_path):
            try:
                content = read_file(file_path)
                full_question += f'\n<file name="{file_name}" path="{file_name}" readonly>\n<![CDATA[\n{content}\n]]>\n</file>\n'
            except Exception as e:
                full_question += f"\n⚠️ Error reading context file {file_name}: {str(e)}\n"

    for file_name, file_path in valid_files:
        try:
            content = read_file(file_path)
            full_question += f'\n<file name="{file_name}" path="{file_path}">\n<![CDATA[\n{content}\n]]>\n</file>\n'
        except Exception as e:
            full_question += f"\n⚠️ Error reading file {file_name}: {str(e)}\n"

    return full_question

def create_driver(profile_dir, proxy):
    CHROMEDRIVER_PATH = "/usr/bin/chromedriver"

    ensure_dir(profile_dir)

    print(f"📁 Using existing profile: {profile_dir}")

    print("🚀 Launching browser...")

    options = webdriver.ChromeOptions()
    options.add_argument('--no-sandbox')
    options.add_argument('--disable-dev-shm-usage')
    options.add_argument("--disable-blink-features=AutomationControlled")
    options.add_argument(f'--user-data-dir={profile_dir}')
    options.add_experimental_option("excludeSwitches", ["enable-automation"])
    options.add_experimental_option("useAutomationExtension", False)

    if proxy:
        print(f"🌐 Using proxy: {proxy}")
        options.add_argument(f'--proxy-server={proxy}')

    prefs = {
        "profile.default_content_setting_values.geolocation": 2
    }
    options.add_experimental_option("prefs", prefs)

    service = Service(executable_path=CHROMEDRIVER_PATH)
    return webdriver.Chrome(service=service, options=options)


def send_prompt(driver, model, full_question, debug, debug_dir):
    print(f"📄 Opening {model.capitalize()}...")
    driver.get(MODEL_CONFIG[model]["url"])

    if debug:
        timestamp = time.strftime("%Y%m%d_%H%M%S")
        prompt_debug_path = os.path.join(debug_dir, f"prompt_{timestamp}.txt")
        write_file(prompt_debug_path, full_question)
        print(f"🐛 Debug: Prompt saved to {prompt_debug_path}")

    config = MODEL_CONFIG[model]

    if model in ("claude", "chatgpt"):
        full_question = "\n".join(
            f"<p>{html.escape(line)}</p>"
            for line in full_question.splitlines()
        )

    wait = WebDriverWait(driver, 600)
    wait.until(EC.presence_of_element_located((By.CSS_SELECTOR, config["input_selector"])))
    input_element = driver.find_element(By.CSS_SELECTOR, config["input_selector"])
    print("✅ Page is ready!")

    input_element.send_keys(" ")
    time.sleep(1)
    driver.execute_script(config["fill_script"], input_element, full_question)
    time.sleep(1)
    input_element.send_keys(" ")
    print("✅ Question and file content sent")

    send_buttons = driver.find_elements(By.CSS_SELECTOR, config["send_selector"])
    if send_buttons:
        send_buttons[config["send_index"]].click()
        print("📨 Message sent, waiting for response...")
    else:
        print("❌ Send button not found!")
        return False

    wait.until(EC.invisibility_of_element_located((By.CSS_SELECTOR, config["response_selector"])))
    time.sleep(1)

    while True:
        done_buttons = driver.find_elements(By.CSS_SELECTOR, config["done_selector"])
        if config["done_index"]:
            if len(done_buttons) > config["done_index"]:
                break
        else:
            if done_buttons:
                break
        time.sleep(1)

    if debug:
        page_html = driver.page_source
        debug_html_path = os.path.join(debug_dir, f"page_{timestamp}.html")
        write_file(debug_html_path, page_html)
        print(f"🐛 Debug: HTML page saved to {debug_html_path}")

    return True


def process_response(driver, model, valid_files, overwrite, backup_dir, report_dir, CURRENT_DIR, question, file_list):
    config = MODEL_CONFIG[model]
    response_selector = config["response_selector"]

    responses = driver.find_elements(By.CSS_SELECTOR, response_selector)

    if not responses:
        print("❌ No response received")
        return

    try:
        markdown = driver.find_element(By.CSS_SELECTOR, response_selector)
        code_blocks = markdown.find_elements(By.CSS_SELECTOR, "pre")

        if not code_blocks:
            print("⚠️ No code blocks found in response")
            response_text = responses[-1].text
            output_file = os.path.join(CURRENT_DIR, f"full_response_{int(time.time())}.txt")
            with open(output_file, 'w', encoding='utf-8') as f:
                f.write(f"Question: {question}\n")
                f.write(f"Files: {', '.join(file_list)}\n")
                f.write(f"Full response:\n{response_text}\n")
            print(f"💾 Full response saved to {output_file}")
            return

        if len(code_blocks) > 1:
            print("⚠️ Warning: Multiple code blocks found, using first one")

        xml_content = code_blocks[0].text

        pattern = re.compile(
            r'<file\s+name="(?P<name>[^"]+)"\s+path="(?P<path>[^"]+)"(?:\s+action="(?P<action>[^"]+)")?[^>]*>\s*(?:<!\[CDATA\[)?(?P<content>.*?)(?:\]\]>)?\s*</file>',
            re.DOTALL
        )
        matches = list(pattern.finditer(xml_content))

        if not matches:
            print("⚠️ No <file> tags found in XML response")
            return

        print(f"✅ {len(matches)} file(s) found in response")

        diffs = []

        for match in matches:
            file_name = match.group("name")
            file_path = match.group("path")
            action = (match.group("action") or "edit").lower()
            code_content = match.group("content").strip()

            if not os.path.isabs(file_path):
                file_path = os.path.join(os.getcwd(), file_path)

            is_new_file = action == "create"

            if is_new_file:
                print(f"🆕 New file to create: {file_name}")
            else:
                print(f"✏️  Editing existing file: {file_name}")

            old_content = ""
            if os.path.exists(file_path):
                old_content = read_file(file_path)

                ts = time.strftime("%Y%m%d%H%M%S")
                rel_path = os.path.relpath(file_path, os.getcwd())
                rel_dir = os.path.dirname(rel_path)
                name, ext = os.path.splitext(os.path.basename(file_path))

                if rel_dir and rel_dir != '.':
                    backup_subdir = os.path.join(backup_dir, rel_dir)
                    ensure_dir(backup_subdir)
                    backup_path = os.path.join(backup_subdir, f"{name}_{ts}{ext}")
                else:
                    backup_path = os.path.join(backup_dir, f"{name}_{ts}{ext}")

                ensure_dir(os.path.dirname(backup_path))
                write_file(backup_path, old_content)
                print(f"🗂 Backup: {backup_path}")

            if overwrite:
                ensure_dir(os.path.dirname(os.path.abspath(file_path)))
                write_file(file_path, code_content)
                if is_new_file:
                    print(f"🆕 Created: {file_path} ({len(code_content)} characters)")
                else:
                    print(f"💾 Saved: {file_path} ({len(code_content)} characters)")
            else:
                diff = list(difflib.unified_diff(
                    old_content.splitlines(),
                    code_content.splitlines(),
                    fromfile='/dev/null' if is_new_file else 'old',
                    tofile='new',
                    lineterm=''
                ))
                diffs.append((file_name, diff, action))
                if is_new_file:
                    print(f"⚠️ New file diff prepared: {file_name}")
                else:
                    print(f"⚠️ Diff prepared: {file_name}")

        if not overwrite and diffs:
            report_file = os.path.join(report_dir, f"diff_{int(time.time())}.html")
            generate_diff_html(diffs, report_file)
            print(f"📊 Diff report saved: {report_file}")
            webbrowser.open(f"file://{report_file}")

    except Exception as e:
        print(f"❌ Error extracting code: {str(e)}")

def main():
    (question, file_list, context_files, overwrite, debug, 
     history_mode, rollback_mode, target_file, rollback_timestamp, browser_only_mode, proxy, model) = parse_args()

    current_dir = os.getcwd()
    HOME_DIR = os.path.expanduser("~")

    BASE_DIR = os.path.join(HOME_DIR, ".codient")
    backup_dir = os.path.join(BASE_DIR, "backups")
    report_dir = os.path.join(BASE_DIR, "reports")
    profile_dir = os.path.join(BASE_DIR, "chrome-profile")
    debug_dir = os.path.join(BASE_DIR, "debug")

    for d in [BASE_DIR, backup_dir, report_dir, profile_dir, debug_dir]:
        ensure_dir(d)

    if browser_only_mode:
        print("\n🌐 Starting browser in standalone mode...")
        print("📝 Please login and do whatever you need.")
        print("🔒 Session cookies will be saved.")
        print("❌ Close the browser window when you're done.\n")

        driver = create_driver(profile_dir, proxy)
        driver.get(MODEL_CONFIG[model]["url"])

        try:
            while True:
                time.sleep(2)
                try:
                    driver.current_url
                except:
                    print("\n✅ Browser closed. Session saved!")
                    break
        except KeyboardInterrupt:
            print("\n⚠️ Interrupted by user")
        finally:
            try:
                driver.quit()
            except:
                pass
        return

    if history_mode and target_file:
        show_history(backup_dir, target_file)
        return

    if rollback_mode and target_file:
        rollback_file(backup_dir, target_file, rollback_timestamp)
        return

    valid_files = collect_files(file_list, current_dir) if file_list else []

    print(f"\n📝 Your question: {question}")
    if valid_files:
        print(f"📁 Number of files: {len(valid_files)}")
    else:
        print("📁 No input files — AI will create new file(s) from scratch")

    if debug:
        print("🐛 Debug mode is ENABLED - Saving prompt, input, and response HTML")

    full_question = build_prompt(question, context_files, valid_files, current_dir)

    CURRENT_DIR = os.path.dirname(os.path.abspath(__file__))

    driver = create_driver(profile_dir, proxy)

    try:
        success = send_prompt(driver, model, full_question, debug, debug_dir)

        if success:
            process_response(
                driver,
                model,
                valid_files,
                overwrite,
                backup_dir,
                report_dir,
                CURRENT_DIR,
                question,
                file_list
            )

        print(f"💾 History and session saved in: {profile_dir}")

    except Exception as e:
        print(f"❌ Error: {str(e)}")

    finally:
        driver.quit()
        print("✅ Browser closed - Profile information saved")


if __name__ == "__main__":
    main()