import os
import sys
import time
import difflib
import webbrowser
import glob
from datetime import datetime


def ensure_dir(path):
    os.makedirs(path, exist_ok=True)


def read_file(path):
    with open(path, 'r', encoding='utf-8') as f:
        return f.read()


def write_file(path, content):
    with open(path, 'w', encoding='utf-8') as f:
        f.write(content)


def show_history(backup_dir, file_name):
    base_name = os.path.splitext(file_name)[0]
    ext = os.path.splitext(file_name)[1]
    pattern = os.path.join(backup_dir, f"{base_name}_*{ext}")
    backups = glob.glob(pattern)
    
    if not backups:
        print(f"\n❌ No backup versions found for '{file_name}'")
        return
    
    backup_list = []
    for backup in backups:
        timestamp_str = backup.replace(backup_dir, "").replace(base_name, "").replace(ext, "").replace("_", "").replace("/", "")
        if timestamp_str.isdigit() and len(timestamp_str) == 14:
            try:
                dt = datetime.strptime(timestamp_str, "%Y%m%d%H%M%S")
                backup_list.append((dt, timestamp_str, backup))
            except:
                continue
    
    backup_list.sort(reverse=True)
    
    print(f"\n📋 Backup history for '{file_name}':")
    print("=" * 70)
    for idx, (dt, ts, path) in enumerate(backup_list, 1):
        print(f"{idx}. Time: {dt.strftime('%Y-%m-%d %H:%M:%S')} (timestamp: {ts})")
        print(f"   Path: {path}")
    print("=" * 70)


def rollback_file(backup_dir, file_name, timestamp=None):
    current_dir = os.getcwd()
    target_file_path = os.path.join(current_dir, file_name)
    
    if not os.path.exists(target_file_path):
        print(f"❌ File '{file_name}' does not exist in current directory")
        return False
    
    base_name = os.path.splitext(file_name)[0]
    ext = os.path.splitext(file_name)[1]
    
    if timestamp:
        backup_path = os.path.join(backup_dir, f"{base_name}_{timestamp}{ext}")
        if os.path.exists(backup_path):
            current_backup = os.path.join(backup_dir, f"{base_name}_{time.strftime('%Y%m%d%H%M%S')}{ext}")
            current_content = read_file(target_file_path)
            write_file(current_backup, current_content)
            print(f"🗂 Backup of current version: {current_backup}")
            
            backup_content = read_file(backup_path)
            write_file(target_file_path, backup_content)
            print(f"✅ File '{file_name}' rolled back to version {timestamp}")
            return True
        else:
            print(f"❌ Version with timestamp '{timestamp}' not found for '{file_name}'")
            return False
    else:
        pattern = os.path.join(backup_dir, f"{base_name}_*{ext}")
        backups = glob.glob(pattern)
        
        if not backups:
            print(f"❌ No backup versions found for '{file_name}'")
            return False
        
        latest_backup = max(backups, key=os.path.getmtime)
        
        ts = latest_backup.replace(backup_dir, "").replace(base_name, "").replace(ext, "").replace("_", "").replace("/", "")
        
        current_backup = os.path.join(backup_dir, f"{base_name}_{time.strftime('%Y%m%d%H%M%S')}{ext}")
        current_content = read_file(target_file_path)
        write_file(current_backup, current_content)
        print(f"🗂 Backup of current version: {current_backup}")
        
        backup_content = read_file(latest_backup)
        write_file(target_file_path, backup_content)
        print(f"✅ File '{file_name}' rolled back to latest version (timestamp: {ts})")
        return True


def generate_diff_html(diffs, output_path):
    html_content = """
    <html>
    <head>
        <meta charset="UTF-8">
        <title>Deep Insight Diff Report</title>
        <style>
            body { font-family: monospace; background: #111; color: #eee; }
            .file { margin-bottom: 40px; }
            .filename { font-size: 18px; margin: 10px 0; }

            .line {
                display: inline-block;
                white-space: pre;
                padding-left: 6px;
                margin: 0;
            }

            .added {
                background: #144212;
                color: #9cff9c;
            }

            .removed {
                background: #4a1212;
                color: #ff9c9c;
            }

            .same {
                color: #ccc;
            }

            .added::before {
                content: "+ ";
                color: #6fff6f;
                user-select: none;
            }

            .removed::before {
                content: "- ";
                color: #ff6f6f;
                user-select: none;
            }

            .same::before {
                content: "  ";
                user-select: none;
            }

            pre {
                padding: 10px;
                overflow-x: auto;
            }
        </style>
    </head>
    <body>
    <h1>Deep Insight Diff Report</h1>
    """

    for file_name, diff_lines in diffs:
        html_content += f"<div class='file'><div class='filename'>{file_name}</div><pre>"

        for line in diff_lines:
            if line.startswith('+++') or line.startswith('---'):
                continue

            clean_line = line[1:] if line.startswith(('+', '-')) else line

            if line.startswith('+'):
                html_content += f"<span class='line added'>{clean_line}</span>\n"
            elif line.startswith('-'):
                html_content += f"<span class='line removed'>{clean_line}</span>\n"
            else:
                html_content += f"<span class='line same'>{clean_line}</span>\n"

        html_content += "</pre></div>"

    html_content += "</body></html>"

    write_file(output_path, html_content)

